{
  "name": "agent-tree-orchestrator",
  "version": "1.0.0",
  "description": "Agent Tree Orchestrator - Recursive AI agent decomposition and execution platform",
  "private": true,
  "workspaces": [
    "src/client",
    "src/server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=src/server",
    "dev:client": "npm run dev --workspace=src/client",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd src/server && npx tsc -p tsconfig.server.json && mkdir -p ../../dist/server/db && cp db/schema.sql ../../dist/server/db/schema.sql",
    "build:client": "cd src/client && npx vite build",
    "start": "NODE_ENV=production node dist/server/index.js",
    "lint": "eslint 'src/**/*.{ts,tsx}' --fix",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "kingdom-raven": "git+https://HandelSim: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@github.com/HandelSim/kingdom-raven.git",
    "nats": "^2.29.3"
  }
}
