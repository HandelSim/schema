{
  "name": "schema",
  "version": "1.0.0",
  "description": "SCHEMA - Self-Constructing Hierarchy for Entire Managed Applications",
  "private": true,
  "workspaces": [
    "src/client",
    "src/server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=src/server",
    "dev:client": "npm run dev --workspace=src/client",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd src/server && npx tsc -p tsconfig.server.json && mkdir -p ../../dist/server/db ../../dist/server/config && cp db/schema.sql ../../dist/server/db/schema.sql && cp config/hammer-capabilities.json ../../dist/server/config/hammer-capabilities.json",
    "build:client": "cd src/client && npx vite build",
    "start": "NODE_ENV=production node dist/server/index.js",
    "lint": "eslint 'src/**/*.{ts,tsx}' --fix",
    "type-check": "tsc --noEmit",
    "test:e2e": "SCHEMA_MODEL=haiku npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:creation": "npx playwright test tests/e2e/01-project-creation.spec.ts",
    "test:e2e:decomposition": "npx playwright test tests/e2e/02-decomposition.spec.ts",
    "test:e2e:inspection": "npx playwright test tests/e2e/03-node-inspection.spec.ts",
    "test:e2e:approval": "npx playwright test tests/e2e/04-approval-flow.spec.ts",
    "test:e2e:workflow": "npx playwright test tests/e2e/05-full-workflow.spec.ts",
    "test:e2e:streaming": "npx playwright test tests/e2e/06-streaming-workflow.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@handelSim/hammer": "file:../tmp/hammer",
    "kingdom-raven": "git+https://HandelSim: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@github.com/HandelSim/kingdom-raven.git",
    "kingdom-services": "git+https://HandelSim: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@github.com/HandelSim/kingdom-services.git",
    "kingdom-session-manager": "git+https://HandelSim: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@github.com/HandelSim/kingdom-session-manager.git",
    "kingdom-tools": "git+https://HandelSim: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@github.com/HandelSim/kingdom-tools.git",
    "nats": "^2.29.3"
  }
}
